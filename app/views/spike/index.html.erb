<h1>Terminal Spike</h1>
<p>Pick a running VM to open a PTY session.</p>

<ul>
  <% if @vms.empty? %>
    <li>No running VMs</li>
  <% else %>
    <% @vms.each do |vm| %>
      <li>
        <%= vm.name %> (<%= vm.state %>)
        <%= button_to "Open terminal", spike_terminals_path(vm_name: vm.name), method: :post %>
      </li>
    <% end %>
  <% end %>
</ul>
