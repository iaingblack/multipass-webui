<div class="p-6 fade-in">
  <h1 class="text-lg font-semibold mb-4"><%= @webhook.persisted? ? "Edit Webhook" : "New Webhook" %></h1>

  <%= form_with model: @webhook, local: true, class: "space-y-4 max-w-2xl" do |f| %>
    <% if @webhook.errors.any? %>
      <div class="px-3 py-2 rounded text-sm" style="background-color: rgba(239,68,68,0.1); color: var(--danger);">
        <%= @webhook.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm mb-1" %>
      <%= f.text_field :name, class: "w-full px-3 py-2 rounded text-sm",
            style: "background-color: var(--bg-primary); border: 1px solid var(--border);" %>
    </div>
    <div>
      <%= f.label :url, class: "block text-sm mb-1" %>
      <%= f.url_field :url, placeholder: "https://example.com/hook",
            class: "w-full px-3 py-2 rounded text-sm font-mono",
            style: "background-color: var(--bg-primary); border: 1px solid var(--border);" %>
    </div>
    <div>
      <%= f.label :secret, "HMAC secret (optional, signs body with X-PassGo-Signature)", class: "block text-sm mb-1" %>
      <%= f.text_field :secret, placeholder: @webhook.persisted? ? "(unchanged)" : "",
            class: "w-full px-3 py-2 rounded text-sm font-mono",
            style: "background-color: var(--bg-primary); border: 1px solid var(--border);" %>
    </div>
    <div>
      <span class="block text-sm mb-1">Categories (leave empty = all)</span>
      <div class="flex flex-wrap gap-2">
        <% Webhook::CATEGORIES.each do |c| %>
          <label class="flex items-center gap-1 text-sm">
            <%= check_box_tag "webhook[categories][]", c, @webhook.categories&.include?(c) %>
            <%= c %>
          </label>
        <% end %>
      </div>
    </div>
    <div>
      <span class="block text-sm mb-1">Results (leave empty = all)</span>
      <div class="flex flex-wrap gap-2">
        <% Webhook::RESULTS.each do |r| %>
          <label class="flex items-center gap-1 text-sm">
            <%= check_box_tag "webhook[results][]", r, @webhook.results&.include?(r) %>
            <%= r %>
          </label>
        <% end %>
      </div>
    </div>
    <div>
      <label class="flex items-center gap-2 text-sm">
        <%= f.check_box :enabled %>
        <%= f.label :enabled %>
      </label>
    </div>
    <div class="flex justify-end gap-2">
      <%= link_to "Cancel", webhooks_path,
            class: "px-3 py-1.5 rounded text-sm",
            style: "background-color: var(--bg-hover); color: var(--text-primary);" %>
      <%= f.submit "Save", class: "px-3 py-1.5 rounded text-sm",
            style: "background-color: var(--accent); color: white;" %>
    </div>
  <% end %>
</div>
