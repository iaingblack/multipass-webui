<div class="p-6 fade-in">
  <h1 class="text-lg font-semibold mb-4"><%= @schedule.persisted? ? "Edit Schedule" : "Edit Schedule" %></h1>

  <%= form_with model: @schedule, local: true, class: "space-y-4 max-w-2xl" do |f| %>
    <% if @schedule.errors.any? %>
      <div class="px-3 py-2 rounded text-sm" style="background-color: rgba(239,68,68,0.1); color: var(--danger);">
        <%= @schedule.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm mb-1" %>
      <%= f.text_field :name, class: "w-full px-3 py-2 rounded text-sm",
            style: "background-color: var(--bg-primary); border: 1px solid var(--border);" %>
    </div>
    <div class="grid grid-cols-3 gap-3">
      <div>
        <%= f.label :action, class: "block text-sm mb-1" %>
        <%= f.select :action, Schedule::ACTIONS, {},
              class: "w-full px-3 py-2 rounded text-sm",
              style: "background-color: var(--bg-primary); border: 1px solid var(--border);" %>
      </div>
      <div>
        <%= f.label :time, "Time (HH:MM, 24h)", class: "block text-sm mb-1" %>
        <%= f.text_field :time, placeholder: "09:00",
              class: "w-full px-3 py-2 rounded text-sm font-mono",
              style: "background-color: var(--bg-primary); border: 1px solid var(--border);" %>
      </div>
      <div>
        <%= f.label :enabled, class: "block text-sm mb-1" %>
        <%= f.check_box :enabled, class: "mt-2" %>
      </div>
    </div>
    <div>
      <span class="block text-sm mb-1">Days</span>
      <div class="flex gap-2">
        <% Schedule::DAYS_OF_WEEK.each_with_index do |day_name, i| %>
          <label class="flex items-center gap-1 text-sm">
            <%= check_box_tag "schedule[days][]", i, @schedule.days&.include?(i) %>
            <%= day_name %>
          </label>
        <% end %>
      </div>
    </div>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <%= f.label :group_name, "Target group (or leave blank for VMs)", class: "block text-sm mb-1" %>
        <%= f.text_field :group_name, class: "w-full px-3 py-2 rounded text-sm",
              style: "background-color: var(--bg-primary); border: 1px solid var(--border);" %>
      </div>
      <div>
        <%= f.label :playbook, "Playbook (if action=playbook)", class: "block text-sm mb-1" %>
        <%= f.text_field :playbook, class: "w-full px-3 py-2 rounded text-sm font-mono",
              style: "background-color: var(--bg-primary); border: 1px solid var(--border);" %>
      </div>
    </div>
    <div class="flex justify-end gap-2">
      <%= link_to "Cancel", schedules_path,
            class: "px-3 py-1.5 rounded text-sm",
            style: "background-color: var(--bg-hover); color: var(--text-primary);" %>
      <%= f.submit "Save", class: "px-3 py-1.5 rounded text-sm",
            style: "background-color: var(--accent); color: white;" %>
    </div>
  <% end %>
</div>
