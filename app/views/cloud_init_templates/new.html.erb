<div class="p-6 fade-in">
  <h1 class="text-lg font-semibold mb-4">New Cloud-Init Template</h1>

  <% if flash[:alert] %>
    <div class="mb-4 px-3 py-2 rounded text-sm"
         style="background-color: rgba(239, 68, 68, 0.1); color: var(--danger);">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: cloud_init_templates_path, method: :post, local: true, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :name, "Filename (e.g. docker.yml)", class: "block text-sm mb-1" %>
      <%= f.text_field :name, value: @template.name, required: true,
            class: "w-full px-3 py-2 rounded text-sm font-mono",
            style: "background-color: var(--bg-primary); border: 1px solid var(--border);" %>
    </div>
    <div>
      <%= f.label :content, "YAML content", class: "block text-sm mb-1" %>
      <%= f.text_area :content, value: @template.content, rows: 20,
            data: { controller: "codemirror" },
            class: "w-full px-3 py-2 rounded text-sm font-mono",
            style: "background-color: var(--bg-primary); border: 1px solid var(--border);" %>
    </div>
    <div class="flex justify-end gap-2">
      <%= link_to "Cancel", cloud_init_templates_path,
            class: "px-3 py-1.5 rounded text-sm",
            style: "background-color: var(--bg-hover); color: var(--text-primary);" %>
      <%= f.submit "Save",
            class: "px-3 py-1.5 rounded text-sm",
            style: "background-color: var(--accent); color: white;" %>
    </div>
  <% end %>
</div>
