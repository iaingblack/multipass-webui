<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Multipass WebUI" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Multipass WebUI">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>
  <body class="h-screen flex flex-col">
    <% if flash[:notice] || flash[:alert] %>
      <div class="fixed top-4 right-4 z-50 px-4 py-2 rounded shadow-lg text-sm
                  <%= flash[:alert] ? 'bg-red-600' : 'bg-blue-600' %> text-white">
        <%= flash[:notice] || flash[:alert] %>
      </div>
    <% end %>

    <% if logged_in? %>
      <header class="flex items-center justify-between px-4 h-12 shrink-0"
              style="background-color: var(--bg-secondary); border-bottom: 1px solid var(--border);">
        <div class="flex items-center gap-3">
          <span class="text-base font-semibold">Multipass WebUI</span>
        </div>
        <div class="flex items-center gap-4 text-sm">
          <span style="color: var(--text-secondary);"><%= current_setting.username %></span>
          <%= button_to "Sign out", login_path, method: :delete,
                class: "hover:underline",
                style: "color: var(--text-secondary);" %>
        </div>
      </header>

      <div class="flex flex-1 overflow-hidden">
        <aside class="w-64 shrink-0 overflow-y-auto"
               style="background-color: var(--bg-secondary); border-right: 1px solid var(--border);">
          <%= turbo_frame_tag "tree", src: tree_path, refresh: :morph do %>
            <div class="p-4 text-sm" style="color: var(--text-secondary);">Loading tree…</div>
          <% end %>
        </aside>

        <main class="flex-1 overflow-y-auto" style="background-color: var(--bg-primary);">
          <%= yield %>
        </main>
      </div>

      <footer class="flex items-center justify-between px-4 h-8 shrink-0 text-xs"
              style="background-color: var(--bg-secondary); border-top: 1px solid var(--border); color: var(--text-secondary);">
        <span>Connected</span>
        <span>Multipass WebUI</span>
      </footer>
    <% else %>
      <main class="flex-1 flex items-center justify-center">
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
