<div class="p-3"
     data-controller="polling"
     data-polling-interval-value="3000"
     data-polling-frame-id-value="tree">
  <!-- Host node -->
  <%= link_to host_path, data: { turbo_frame: "_top" },
        class: "flex items-center gap-2 px-2 py-1.5 rounded text-sm hover:bg-[var(--bg-hover)] #{request.path == host_path ? 'bg-[var(--bg-hover)]' : ''}" do %>
    <span class="w-2 h-2 rounded-full" style="background-color: var(--success);"></span>
    <span class="font-medium">Host</span>
    <span class="ml-auto text-xs" style="color: var(--text-secondary);">
      <%= @vms.length %> VM<%= 's' unless @vms.length == 1 %>
    </span>
  <% end %>

  <!-- Sidebar sections (placeholders for later phases) -->
  <div class="mt-3 space-y-0.5">
    <% [
      { label: "Cloud-Init", path: "#" },
      { label: "Ansible", path: "#" },
      { label: "Profiles", path: "#" },
      { label: "Schedules", path: "#" },
      { label: "Webhooks", path: "#" },
      { label: "API Tokens", path: "#" },
      { label: "Events", path: "#" },
      { label: "Settings", path: "#" }
    ].each do |section| %>
      <a href="<%= section[:path] %>"
         class="block px-2 py-1 rounded text-sm hover:bg-[var(--bg-hover)]"
         style="color: var(--text-secondary);">
        <%= section[:label] %>
      </a>
    <% end %>
  </div>

  <!-- VM list -->
  <% if @vms.any? %>
    <div class="mt-4 space-y-0.5">
      <div class="px-2 mb-1 text-xs uppercase tracking-wide"
           style="color: var(--text-secondary);">Instances</div>
      <% @vms.each do |vm| %>
        <%= link_to vm_path(vm.name),
              data: { turbo_frame: "_top" },
              class: "flex items-center gap-2 px-2 py-1 rounded text-sm hover:bg-[var(--bg-hover)] #{request.path == vm_path(vm.name) ? 'bg-[var(--bg-hover)]' : ''}",
              title: "<%= vm.state %>" do %>
          <%= render "status_dot", state: vm.state %>
          <span><%= vm.name %></span>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="mt-4 px-2 py-4 text-xs text-center"
         style="color: var(--text-secondary);">
      No VMs found
    </div>
  <% end %>

  <!-- Spike link (temporary, removed in Phase 3) -->
  <div class="mt-6 pt-3 border-t" style="border-color: var(--border);">
    <%= link_to "Terminal spike", spike_path,
          class: "block px-2 py-1 text-xs hover:underline",
          style: "color: var(--text-secondary);" %>
  </div>
</div>
